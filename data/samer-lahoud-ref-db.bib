@incollection{maaz:2018dp,
	abstract = {The migration to smart cities will provide citizens with a
		  plethora of services under the umbrella of Internet of
		  Things, such as real time health monitoring, smart
		  vehicular, and road control systems. To meet smart cities'
		  needs, technological development in the fields of Smart
		  Grid, Big Data processing and Broadband Communication, has
		  started. In particular, the development in the domain of
		  broadband communication must take into account data rate
		  maximization and latency minimization, while keeping eyes
		  on the environmental friendly aspect. One promising concept
		  in this context is the heavy deployment of 4G and beyond
		  networks where energy efficiency is a major focal point.
		  Hence, the focus of this chapter is targeted towards green
		  multicell networks, where dense frequency reutilization is
		  used in smart cities. The ensuing Inter-Cell Interference
		  (ICI) harms radio transmissions and degrades their
		  performances. Thus, a certain degree of ICI Coordination
		  (ICIC) between serving evolved Node B (eNBs) is required to
		  manage the resources and minimize the interference level.},
	address = {Singapore},
	author = {Maaz, Bilal and Khawam, Kinda and Lahoud, Samer and Nasreddine, Jad and Tohme, Samir},
	booktitle = {Information Innovation Technology in Smart Cities},
	date-modified = {2021-06-05 12:51:15 +0300},
	doi = {10.1007/978-981-10-1741-4_19},
	editor = {Ismail, Leila and Zhang, Liren},
