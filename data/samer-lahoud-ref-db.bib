@article{drid:2010vo,
	abstract = {Survivability is becoming an important issue in optical
		  networks due to the huge bandwidth offered by optical
		  technology. Many works have studied network survivability.
		  The majority of these works are destined for single-domain
		  networks. In this work, we address the survivability of
		  multi-domain optical networks. This paper provides a
		  classification of the existing protection solutions
		  proposed for multi-domain networks and analyses their
		  advantages and limitations. We propose a new solution for
		  multi-domain optical networks based on p-cycles
		  (pre-configured cycles). For scalability and security
		  reasons, we also propose a topology aggregation model
		  adapted to p-cycle computations. This aggregation model
		  allows our proposed solution to find a trade-off between
		  two competing goals: efficient use of backup resources and
		  short running time. Simulation results show that the
		  proposed solution is a good trade-off between resource
		  utilization and running time compared to existing
		  solutions.},
	affiliation = {University of Rennes I - IRISA Campus universitaire de Beaulieu Rennes 35042 France},
	author = {Hamza Drid and Samer Lahoud and Bernard Cousin and Miklos Molnar},
	doi = {http://dx.doi.org/10.1007/s11107-009-0213-y},
	issn = {1387-974X},
	issue = {1},
	journal = {Photonic Network Communications},
	keyword = {Computer Science},
	pages = {81-89},
	pdf = {http://dl.dropboxusercontent.com/u/45967765/Publications/photonic-09.pdf},
	publisher = {Springer Netherlands},
	title = {Survivability in multi-domain optical networks using p-cycles},
	volume = {19},
	year = {2010},
	bdsk-url-1 = {http://dx.doi.org/10.1007/s11107-009-0213-y}}

@inproceedings{drid:2009fd,
	abstract = {Survivability becomes an important issue in optical
