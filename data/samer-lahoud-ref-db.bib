	title = {Hybrid Inter-Domain QoS Routing with Crankback Mechanisms},
	year = {2011},
	bdsk-url-1 = {http://dx.doi.org/10.1007/978-3-642-22875-9%5C_41}}

@article{frikha:2013lp,
	author = {Ahmed Frikha and Samer Lahoud and Bernard Cousin},
	doi = {http://dx.doi.org/10.1007/s10922-013-9273-5},
