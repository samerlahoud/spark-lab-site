	pages = {291--302},
	pdf = {http://samer.lahoud.fr/pub-pdf/springer-18.pdf},
	publisher = {Springer Singapore},
	title = {Achieving Spectral and Energy Efficiencies in Smart Cities Multi-cell Networks},
	url = {https://doi.org/10.1007/978-981-10-1741-4_19},
	year = {2018},
	bdsk-url-1 = {https://doi.org/10.1007/978-981-10-1741-4_19}}

