	doi = {10.1007/s11235-023-01048-8},
	id = {Loubany2023},
	isbn = {1572-9451},
	journal = {Telecommunication Systems},
	number = {2},
	pages = {271--283},
	title = {Joint throughput-energy optimization in multi-gateway LoRaWAN networks},
	url = {https://doi.org/10.1007/s11235-023-01048-8},
