@inproceedings{bertrand:2009qm,
	abstract = {The present paper proposes a novel method for computing
		  inter-domain paths subject to multiple independent additive
		  constraints in MPLS-TE networks. An efficient solution to
		  this problem is a key element for providing services with
		  guaranteed performance across domain boundaries. However,
		  the inherent hardness of the multi-constrained path
		  computation as well as inter-domain scalability and
		  security constraints complicate the computation problem. We
		  propose a novel algorithm named kID-MCP that tackles the
		  computational complexity of the problem by reducing the
		  number of paths included in the computation process.
		  kID-MCP is compatible with existing techniques and fulfills
		  the security requirements. We undergo a complexity analysis
		  that shows that kID-MCP scales well. Moreover, a simulation
		  study reveals that kID-MCP finds a solution in most
		  situations. These results indicate that the computation of
		  inter-domain multi-constrained paths is tractable in
		  practice, which opens interesting perspectives for QoS
		  routing and traffic engineering among multiple operators.},
	address = {Aveiro, Portugal},
	author = {Gilles Bertrand and Samer Lahoud and Geraldine Texier and Miklos Molnar},
	booktitle = {Next Generation Internet Networks, NGI '09},
	doi = {http://dx.doi.org/10.1109/NGI.2009.5175757},
	keywords = {QoS routing;computational complexity analysis;inter-domain multi-constrained path computation;inter-domain scalability;multi-domain MPLS-TE networks;multiple independent additive constraints;quality of service;security constraints;traffic engineering;computational complexity;computer network performance evaluation;quality of service;},
	month = {July},
	pages = {1 -8},
	pdf = {http://dl.dropboxusercontent.com/u/45967765/Publications/ngi-09.pdf},
	title = {Computation of Multi-Constrained Paths in Multi-Domain MPLS-TE Networks},
	year = {2009},
	bdsk-url-1 = {http://dx.doi.org/10.1109/NGI.2009.5175757}}

