@inproceedings{belghith:2012pt,
	abstract = {The monitoring of the quality of service in a multi-domain
		  network supervises the multi-domain service performance. A
		  multi-domain service is a service that crosses several
		  domains which can be managed by different providers. Since
		  each domain can be managed with its own policies and may
		  require confidentiality of its topology and its monitoring
		  processes, we propose that the monitoring architecture has
		  to be configurable. In this paper, we propose two
		  collaboration schemes that are based on the reactive and
		  the proactive modes. Both of collaboration schemes allow
		  the multi-domain monitoring architecture to select the
		  measurement points that will participate in the
		  multi-domain monitoring and to configure the selected
		  measurement points. In this paper, we present our proposed
		  collaboration schemes and then we evaluate their
		  performance through extensive simulations using Network
		  Simulator (NS-2).},
	address = {Hong Kong, P.R. China},
	author = {Aymen Belghith and Siwar BenHadj Said and Bernard Cousin and Samer Lahoud},
	booktitle = {Engineering-IT applications 2012 (EITA 2012)},
	pdf = {http://dl.dropboxusercontent.com/u/45967765/Publications/comcomap-12.pdf},
	title = {Proactive and Reactive Collaboration Schemes for Multi-domain Networks Monitoring},
	year = {2012}}

@inproceedings{belghith:2012oy,
	abstract = {Monitoring the quality of service in a multi-domain
		  network allows providers to ensure the control of
		  multi-domain service performance. A multi-domain service is
		  a service that crosses multiple domains. In this paper, we
		  propose several mechanisms for fault detection and fault
		  localization. A fault is detected when an end-to-end
		  contract is not respected. Faulty domains are domains that
		  do not fulfill their Quality of Service (QoS) requirements.
		  Our three proposed fault detection and localization
		  mechanisms (FDLM) depend on the export method used. These
		  export methods define how the measurement results are
		  exported for analysis. We consider the periodic export, the
		  triggered export, and a combined method. For each FDLM, we
		  propose two sub-schemes that use different fault detection
		  strategies. In this paper, we describe these mechanisms and
		  evaluate their performance using Network Simulator
		  (NS-2).},
	address = {PyeongChang, Korea},
	author = {Aymen Belghith and Siwar BenHadj Said and Bernard Cousin and Samer Lahoud},
	booktitle = {4th International Conference on Advanced Communication Technology 2012 (ICACT 2012)},
	pdf = {http://dl.dropboxusercontent.com/u/45967765/Publications/icact-12.pdf},
	title = {QoS Fault Detection and Localization Mechanisms (FDLM) in Multi-domain Networks Adapted to Export Methods},
	year = {2012}}

