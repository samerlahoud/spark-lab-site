	days = 19,
	keywords = {5G; ICIC; Game Theory; convex optimization.},
	month = mar,
	pdf = {http://samer.lahoud.fr/pub-pdf/wcnc-17.pdf},
	title = {Joint User Association, Power Control and Scheduling in {Multi-Cell} {5G} Networks},
	year = 2017}

